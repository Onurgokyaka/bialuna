---
title: Bialuna Collection
description: Ankara, Sincan/Yenikent ve Eskişehir için eşarp ve şal koleksiyonu
---
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="GnRuVKFL45c5afo0u56h_4v1H401zmMJOhgFjDXNlh0" />

  <title>Eşarp ve Şal Modelleri | {{ site.brandName }}</title>
  <meta name="description" content="Bialuna Collection; zarif eşarp ve şal modelleri sunan butik bir koleksiyondur. Türkiye geneli kargo, Ankara ve Eskişehir için elden teslim seçenekleriyle güncel koleksiyonu inceleyebilirsiniz." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://bialunacollection.pages.dev/" />

  <meta property="og:title" content="Eşarp ve Şal Modelleri | {{ site.brandName }}" />
  <meta property="og:description" content="Zarif eşarp ve şal modellerini inceleyin. Türkiye geneli kargo, Ankara ve Eskişehir için elden teslim seçenekleriyle sipariş bilgisi alabilirsiniz." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://bialunacollection.pages.dev/" />
  <meta property="og:image" content="https://bialunacollection.pages.dev/assets/uploads/esarp-cicek-desenli-glamouria.jpg" />
  <meta property="og:locale" content="tr_TR" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Eşarp ve Şal Modelleri | {{ site.brandName }}" />
  <meta name="twitter:description" content="Bialuna Collection eşarp ve şal modellerini inceleyin. Türkiye geneli kargo, Ankara ve Eskişehir elden teslim seçenekleri için WhatsApp üzerinden bilgi alın." />
  <meta name="twitter:image" content="https://bialunacollection.pages.dev/assets/uploads/esarp-cicek-desenli-glamouria.jpg" />

  <link rel="stylesheet" href="/assets/css/style.css" />
  <link rel="icon" type="image/x-icon" href="/assets/uploads/favicon.ico" />
  <link rel="icon" type="image/png" href="/assets/uploads/favicon.png" />
  <link rel="apple-touch-icon" href="/assets/uploads/apple-touch-icon.png" />
  <meta name="theme-color" content="#f1dfc5" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Store",
    "name": "Bialuna Collection",
    "url": "https://bialunacollection.pages.dev/",
    "description": "Ankara, Sincan/Yenikent ve Eskişehir çevresinde eşarp ve şal modelleri sunan butik koleksiyon.",
    "areaServed": ["Türkiye", "Ankara", "Eskişehir"],
    "sameAs": [
      "https://www.instagram.com/{{ site.instagramHandle }}"
    ]
  }
  </script>
</head>
<body data-whatsapp="{{ site.whatsappNumber }}">
  <header class="site-header">
    <a class="brand" href="#anasayfa" aria-label="{{ site.brandName }} ana sayfa">
      <img class="brand-logo" src="/assets/uploads/bia-luna-logo.jpg" alt="Bia & Luna logo" />
      <span><strong>{{ site.brandShort }}</strong><small>Collection</small></span>
    </a>
    <nav class="nav" aria-label="Ana menü">
      <a href="#urunler">Ürünler</a>
      <a href="#hakkimizda">Hakkımızda</a>
      <a href="#iletisim">İletişim</a>
    </nav>
    <a class="header-action js-whatsapp-general" href="#" target="_blank" rel="noopener">WhatsApp</a>
  </header>

  <main>
    <section class="hero" id="anasayfa">
      <div class="hero-copy">
        <p class="eyebrow">{{ site.announcement }}</p>
        <h1>Zarif Eşarp ve Şal Modelleri</h1>
        <p class="hero-text">Bialuna Collection; günlük kullanım, özel günler ve hediye seçenekleri için sade, şık ve ulaşılabilir eşarp ve şal modelleri sunar. Türkiye geneli kargo, Ankara ve Eskişehir için elden teslim seçenekleri hakkında WhatsApp üzerinden bilgi alabilirsiniz.</p>
        <div class="hero-actions">
          <a class="button primary js-whatsapp-general" href="#" target="_blank" rel="noopener">{{ site.buttonText }}</a>
          <a class="button ghost" href="#urunler">{{ site.secondaryButtonText }}</a>
        </div>
        <div class="mini-trust">
          <span>✓ {{ site.shippingText }}</span>
          <span>✓ {{ site.packagingText }}</span>
          <span>✓ {{ site.orderText }}</span>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-image-wrap">
          <img src="/assets/uploads/esarp-cicek-desenli-glamouria.jpg" alt="Bialuna Collection çiçek desenli eşarp ve şal koleksiyonu" />
        </div>
        <div class="floating-card">
          <span>Yeni koleksiyon</span>
          <strong>Yeni koleksiyon, zarif dokular ve özel desenler</strong>
        </div>
      </div>
    </section>

    <section class="about-strip" id="hakkimizda">
      <div>
        <p class="eyebrow">Hakkımızda</p>
        <h2>Zarif eşarp ve şal koleksiyonu</h2>
      </div>
      <p>Bialuna Collection; zarif eşarp ve şal modelleri sunan butik bir koleksiyondur. Türkiye geneli kargo seçeneğiyle ürünleri inceleyebilir, Ankara ve Eskişehir için elden teslim hakkında WhatsApp üzerinden bilgi alabilirsiniz.</p>
    </section>

    <section class="section" id="urunler">
      <div class="section-head">
        <div>
          <p class="eyebrow">Koleksiyon</p>
          <h2>Eşarp ve Şal Ürünleri</h2>
        </div>
        <a class="text-link" href="https://www.instagram.com/{{ site.instagramHandle }}" target="_blank" rel="noopener">@{{ site.instagramHandle }}</a>
      </div>

      <div class="product-grid">
        {% for product in products %}
        {% if product.active %}
        <article class="product-card">
          <div class="product-image">
            <img src="{{ product.image }}" alt="{{ product.title }} - Bialuna Collection" loading="lazy" />
            {% if product.badge %}<span class="product-badge">{{ product.badge }}</span>{% endif %}
          </div>
          <div class="product-body">
            <h3>{{ product.title }}</h3>
            <p>{{ product.description }}</p>
            <div class="product-bottom">
              <strong>{{ product.price }}</strong>
              <button class="js-whatsapp-product" data-product="{{ product.title }}" data-price="{{ product.price }}">Sipariş Sor</button>
            </div>
          </div>
        </article>
        {% endif %}
        {% endfor %}
      </div>
    </section>

    <section class="features">
      <article><span></span><strong>Modeli seç</strong><p>Beğendiğin eşarp veya şal modelini ürünler arasından kolayca incele.</p></article>
      <article><span></span><strong>Stok bilgisini sor</strong><p>Renk, adet ve güncel stok bilgisi için WhatsApp üzerinden hızlıca yaz.</p></article>
      <article><span></span><strong>Kolay sipariş ver</strong><p>Ürün butonuna tıkladığında WhatsApp mesajı otomatik olarak hazırlanır.</p></article>
    </section>

    <section class="contact" id="iletisim">
      <div class="contact-copy">
        <p class="eyebrow">İletişim</p>
        <h2>{{ site.contactTitle }}</h2>
        <p>{{ site.contactText }}</p>
      </div>
      <form class="contact-form" id="contactForm">
        <label>Ad Soyad<input type="text" id="name" placeholder="Adınızı yazın" autocomplete="name" /></label>
        <label>İlgilendiğiniz ürün<input type="text" id="product" placeholder="Örn: Pudra Yaprak Desenli Şal" /></label>
        <label>Notunuz<textarea id="message" rows="4" placeholder="Renk, adet veya kargo sorusu yazabilirsiniz"></textarea></label>
        <button class="button primary" type="submit">WhatsApp Mesajı Oluştur</button>
      </form>
    </section>
  </main>

  <footer class="site-footer">
    <p>© <span id="year"></span> {{ site.brandName }}. {{ site.footerText }}</p>
    <div>
      <a href="https://www.instagram.com/{{ site.instagramHandle }}" target="_blank" rel="noopener">Instagram</a>
      <a class="js-whatsapp-general" href="#" target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </footer>
  <script src="/assets/js/main.js"></script>
</body>
</html>
